if true
%% =============================================================
%%   SISTEMA 6 - PID
%% =============================================================
disp(' ');
disp('### SISTEMA 6 - PID ###');

% --- Você ajusta os três ganhos ---
% --- PID superamortecido ---
Kp = 0.40;       % ganho proporcional
Ki = 5.60;       % ganho integral
Kd = 0.2;       % ganho derivativo

% Controlador PID discreto (forma posicional, derivada/integral por Euler)
%   C(z) = Kp + Ki*T/(z-1) + Kd/T*(z-1)/z
%   - termo integral  -> polo em z=1 (rastreia referência, erro zero)
%   - termo derivativo -> polo em z=0 (filtra/antecipação)
Cp = tf(Kp, 1, T);                 % proporcional
Ci = tf(Ki*T, [1 -1], T);          % integral  (Ki*T/(z-1))
Cd = tf(Kd/T*[1 -1], [1 0], T);    % derivativo (Kd/T*(z-1)/z)
C_PID = Cp + Ci + Cd;

% Malhas
MA_PID = C_PID*G;
MF_PID = feedback(MA_PID,1);

disp(' ');
disp('Controlador PID');
disp('--- zpk ---');
zpk(C_PID)

%% =============================================================
%%   RESPOSTA AO DEGRAU
%% =============================================================
figure;
step(MA_sc,'b')
hold on
step(MF_PID,'r')
plot(tempo,Vo/ref,'m')
grid on
legend('Sem Controle','PID','Vo Medido')
title('Resposta ao Degrau - PID')
hold off

%% =============================================================
%%   INFORMAÇÕES DA RESPOSTA
%% =============================================================
info_PID = stepinfo(MF_PID);
disp(' ');
disp('### DESEMPENHO PID ###');

disp('Tempo de subida:')
disp(info_PID.RiseTime)

disp('Tempo de acomodacao:')
disp(info_PID.SettlingTime)

disp('Sobressinal (%):')
disp(info_PID.Overshoot)

disp('Valor de pico:')
disp(info_PID.Peak)

%% =============================================================
%%   LUGAR DAS RAÍZES
%% =============================================================
figure;
rlocus(MA_sc,'b')
hold on
rlocus(MA_PID,'r')
zgrid
legend('Sem Controle','PID')
title('Lugar das Raízes - PID vs Sem Controle')
hold off
end

if false
%% =============================================================
%%   POLOS E ZEROS
%% =============================================================
figure;
pzmap(MF_PID)
grid on
title('Polos e Zeros - PID')

%% =============================================================
%%   BODE
%% =============================================================
figure;
margin(MA_PID)
grid on
title('Bode - PID (com margens)')

figure;
bode(MA_sc,'b',MA_PID,'r')
grid on
legend('Sem Controle','PID')
title('Bode - Comparação')

%% =============================================================
%%   NYQUIST
%% =============================================================
figure;
nyquist(MA_sc,'b',MA_PID,'r')
grid on
legend('Sem Controle','PID')
title('Nyquist - Comparação')

%% =============================================================
%%   NICHOLS
%% =============================================================
figure;
nichols(MA_sc,'b',MA_PID,'r')
ngrid
grid on
legend('Sem Controle','PID')
title('Nichols - Comparação')

%% =============================================================
%%   MARGENS DE ESTABILIDADE
%% =============================================================
[Gm, Pm, Wcg, Wcp] = margin(MA_PID);
disp(' ');
disp('### MARGENS - PID ###');
fprintf('Margem de Ganho : %.4g (%.4g dB)\n', Gm,20*log10(Gm));
fprintf('Margem de Fase  : %.4g graus\n', Pm);
fprintf('Wcg (fase=-180°) : %.4g rad/s\n', Wcg);
fprintf('Wcp (ganho=0 dB) : %.4g rad/s\n', Wcp);

%% =============================================================
%%   VERIFICAÇÃO DE ESTABILIDADE
%% =============================================================
disp(' ');
disp('### POLOS DE MALHA FECHADA ###');
pole(MF_PID)

disp(' ');
disp('### AMORTECIMENTO ###');
damp(MF_PID)
end