						<result xmlns="http://schemas.mathsoft.com/math30">
							<ml:real>0.652</ml:real>
						</result>
					</ml:eval>
				</ml:define>
			</math>
			<rendering item-idref="3"/>
		</region>
		<region region-id="19" left="6" top="86.25" width="395.25" height="24" align-x="6" align-y="96" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">ζ (zeta, amortecimento) → tirado do sobre-sinal (quanto a resposta ultrapassa o valor final). Quanto maior o overshoot, menor o ζ.</p>
			</text>
		</region>
